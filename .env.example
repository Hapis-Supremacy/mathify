# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Database config
DB_HOST=db          # DB_HOST must match the service name in compose.yaml
DB_PORT=5432
DB_NAME=mathify
DB_USER=postgres

# Firebase client-side config
# Found in Firebase console → Project settings → Your apps → SDK setup and configuration
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Midtrans payment gateway
# Found in Midtrans dashboard → Settings → Access keys. Use the SANDBOX keys for
# development. Leave MIDTRANS_IS_PRODUCTION=false to stay in test mode (no real money).
MIDTRANS_MERCHANT_ID=
MIDTRANS_CLIENT_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false